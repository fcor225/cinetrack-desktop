# ═══════════════════════════════════════════════════════
# CineTrack Backend — Variables de Entorno
# Copia este archivo a .env y rellena los valores
# ═══════════════════════════════════════════════════════

# Servidor
PORT=5000
NODE_ENV=development

# Base de Datos SQLite (ruta relativa al directorio del backend)
DB_PATH=../../database/cinetrack.db

# JWT — Secreto y expiración
JWT_SECRET=tu_secreto_jwt_super_seguro_cambiar_en_produccion
JWT_EXPIRES_IN=86400

# CORS — Orígenes permitidos (separados por coma)
CORS_ORIGIN=http://localhost:3000

# Frontend URL (para emails de recuperación)
FRONTEND_URL=http://localhost:3000

# TMDB API (The Movie Database)
TMDB_API_KEY=tu_api_key_de_tmdb
TMDB_BASE_URL=https://api.themoviedb.org/3

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
