# ═══════════════════════════════════════════════════════
# CineTrack Frontend — Variables de Entorno
# Copia este archivo a .env y rellena los valores
# ═══════════════════════════════════════════════════════

# URL del backend API
REACT_APP_API_URL=http://localhost:5000/api

# URL de Socket.IO
REACT_APP_SOCKET_URL=http://localhost:5000

# TMDB — Para cargar imágenes directamente
REACT_APP_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p
